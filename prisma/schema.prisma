generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  slug      String   @unique
  timezone  String   @default("UTC") // central time zone
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventTypes             EventType[]
  availabilityRules      AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  slots                  Slot[]
  bookings               Booking[]               @relation("HostBookings")

  @@map("users")
}

model EventType {
  id                  Int       @id @default(autoincrement())
  hostId              Int
  title               String
  description         String?
  slug                String
  durationMinutes     Int
  isActive            Boolean   @default(true)
  locationType        String    @default("Online")
  locationValue       String?
  bufferBeforeMinutes Int       @default(0)
  bufferAfterMinutes  Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  host                User      @relation(fields: [hostId], references: [id], onDelete: Cascade)
  slots               Slot[]
  bookings            Booking[]

  @@unique([hostId, slug]) // combination of hostId and slug to be unique.
  @@map("event_types")
}

model AvailabilityRule {
  id        Int      @id @default(autoincrement())
  userID    Int
  weekday   Int
  startTime String
  endTime   String
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@index([userID, weekday])
  @@map("availability_rules")
}

model AvailabilityException {
  id        Int      @id @default(autoincrement())
  userID    Int
  date      DateTime @db.Date
  type      String
  startTime String?
  endTime   String?
  reason    String?
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userID], references: [id], onDelete: Cascade)

  @@index([userID, date])
  @@map("availability_exceptions")
}

model Slot {
  id          Int      @id @default(autoincrement())
  hostID      Int
  eventTypeId Int
  startAt     DateTime
  endAt       DateTime
  status      String   @default("AVAILABLE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host      User      @relation(fields: [hostID], references: [id], onDelete: Cascade)
  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  bookings Booking[]

  @@unique([eventTypeId, startAt, endAt])
  @@index([hostID, startAt])
  @@index([eventTypeId, startAt, status])
  @@map("slots")
}

model Booking {
  id           Int     @id @default(autoincrement())
  hostID       Int
  eventTypeId  Int
  slotId       Int
  inviteeEmail String
  inviteeNotes String?
  inviteeName  String

  status          String    @default("PENDING")
  meetLink        String?
  calenderEventId String?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  host      User      @relation("HostBookings", fields: [hostID], references: [id], onDelete: Cascade)
  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  slot      Slot      @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([inviteeEmail])
  @@index([hostID, createdAt])
  @@index([status])
  @@map("bookings")
}
